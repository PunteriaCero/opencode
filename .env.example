# ============================================================================
# OpenCode Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment.
# Do NOT commit .env to version control - it contains sensitive credentials.

# ============================================================================
# GitHub Authentication
# ============================================================================
# Personal Access Token for GitHub operations (push, PR, issues, etc.)
# Scopes required: repo (full control of private repositories)
# Used by: github-ops skill, gh CLI, GitHub MCP server
GHUB_PAT=your_github_personal_access_token_here

# ============================================================================
# Portainer Configuration
# ============================================================================
# Base URL to the Portainer instance
# Example: http://192.168.1.100:9000 or https://portainer.example.com
# Used by: portainer-cli skill, portainer-mcp-server
PORTAINER_URL=http://your-portainer-url:9000

# Portainer API token for authentication
# Generate from: Portainer Admin Panel > Account Settings > API tokens
# Used by: portainer-cli skill, portainer-mcp-server
PORTAINER_PAT=your_portainer_api_token_here

# ============================================================================
# N8N Workflow Automation
# ============================================================================
# Base URL to the N8N instance
# Example: http://192.168.1.50:5678 or https://n8n.example.com
# Do NOT include /api/v1 path - provide only the base URL
# Used by: n8n-cli skill, N8N MCP server
N8N_API_URL=http://your-n8n-url:5678

# API key for N8N authentication
# Generate from: N8N Settings > API > Authentication
# Used by: n8n-cli skill, N8N MCP server
N8N_API_KEY=your_n8n_api_key_here

# ============================================================================
# Evolution API (WhatsApp)
# ============================================================================
# Base URL to the Evolution API instance
# Example: https://your-domain.com/api or http://192.168.1.100:8080
# Used by: evolution-api skill for WhatsApp messaging automation
EVOLUTION_API_URL=https://your-evolution-api-url.com

# API key for Evolution API authentication
# Required for all API requests to Evolution
# Used by: evolution-api skill
EVOLUTION_API_KEY=your_evolution_api_key_here

# WhatsApp instance identifier (UUID or instance name)
# Example: 784F3B7A0529-4E4D-AEFC-1178ED9D85A2 or whatsapp-bot-001
# Used by: evolution-api skill to target specific WhatsApp instance
EVOLUTION_API_INSTANCE=your-instance-name-or-uuid

# ============================================================================
# Google Drive Integration
# ============================================================================
# Google OAuth 2.0 client ID
# Generate from: Google Cloud Console > APIs & Services > Credentials
# Used by: Google Drive MCP server
GDRIVE_CLIENT_ID=your_google_client_id_here

# Google OAuth 2.0 client secret
# Generate from: Google Cloud Console > APIs & Services > Credentials
# Used by: Google Drive MCP server
GDRIVE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth 2.0 refresh token
# Obtained after initial OAuth consent flow
# Used by: Google Drive MCP server for persistent authentication
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# ============================================================================
# Home Assistant Integration
# ============================================================================
# Base URL to the Home Assistant instance
# Example: http://192.168.1.50:8123 or https://home-assistant.example.com
# Used by: Home Assistant MCP server (remote connection)
HA_URL=http://your-home-assistant-url:8123

# Home Assistant Personal Access Token
# Generate from: Settings > Devices & Services > Automations & Scenes > Tokens
# Used by: Home Assistant MCP server for API authentication
HA_PAT=your_home_assistant_token_here
