{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "portainer": {
      "type": "local",
      "command": [
        "/usr/local/bin/portainer-mcp",
        "-server", "192.168.0.214:9000",
        "-token", "{env:PORTAINER_PAT}",
        "-disable-version-check"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
      }
    },
    "gdrive": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@hachiai/mcp-google-drive"
      ],
      "enabled": true,
      "environment": {
        "GOOGLE_DRIVE_OAUTH_CREDENTIALS": "/root/.config/mcp-google-drive/gcp-oauth.keys.json",
        "GOOGLE_DRIVE_MCP_TOKEN_PATH": "/root/.config/mcp-google-drive/tokens.json"
      }
    },
    "home-assistant": {
      "type": "remote",
      "url": "{env:HA_URL}/api/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:HA_PAT}"
      }
    }
  }
}